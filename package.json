{
  "name": "phonetastic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "kill-agents": "pkill -9 -f job_proc_lazy_main || true",
    "dev": "npm run kill-agents && tsx watch --import ./src/instrumentation.ts src/server.ts",
    "start": "trap 'kill 0' SIGINT; npm run web:start & npm run agent:start & wait",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:test": "tsx src/db/migrate-test.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed-voices": "tsx src/db/seed-voices.ts",
    "download": "node dist/agent.js download-files",
    "agent:start": "node dist/agent.js start",
    "web:start": "node --import ./dist/instrumentation.js dist/server.js",
    "tunnel": "ngrok http --url=${NGROK_DOMAIN:-localhost} ${PORT:-3333}",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1010.0",
    "@boundaryml/baml": "^0.219.0",
    "@dbos-inc/dbos-sdk": "^2.0.0",
    "@dbos-inc/otel": "^4.11.11",
    "@livekit/agents": "^1.0.50",
    "@livekit/agents-plugin-cartesia": "^1.0.50",
    "@livekit/agents-plugin-deepgram": "^1.0.50",
    "@livekit/agents-plugin-google": "^1.0.50",
    "@livekit/agents-plugin-livekit": "^1.0.50",
    "@livekit/agents-plugin-openai": "^1.0.50",
    "@livekit/agents-plugin-silero": "^1.0.50",
    "@livekit/noise-cancellation-node": "^0.1.9",
    "@mendable/firecrawl-js": "^4.13.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-pino": "^0.59.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@orama/orama": "^3.1.18",
    "@orama/plugin-embeddings": "^3.1.18",
    "@tensorflow/tfjs-node": "^4.22.0",
    "arg": "^5.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "edge.js": "^6.5.0",
    "eta": "^4.5.1",
    "fastify": "^5.2.0",
    "google-auth-library": "^10.5.0",
    "google-libphonenumber": "^3.2.44",
    "jsonld": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.0",
    "node-html-parser": "^7.0.2",
    "openai": "^6.29.0",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-opentelemetry-transport": "^3.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "schema-dts": "^1.1.5",
    "svix": "^1.88.0",
    "tsyringe": "^4.8.0",
    "twilio": "^5.12.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jsonld": "^1.5.15",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "fishery": "^2.4.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
