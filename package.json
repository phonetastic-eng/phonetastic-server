{
  "name": "phonetastic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "kill-agents": "pkill -9 -f job_proc_lazy_main || true",
    "dev": "npm run kill-agents && tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed-voices": "tsx src/db/seed-voices.ts",
    "tunnel": "ngrok http --url=${NGROK_DOMAIN:-localhost} ${PORT:-3333}"
  },
  "dependencies": {
    "@boundaryml/baml": "^0.219.0",
    "@dbos-inc/dbos-sdk": "^2.0.0",
    "@livekit/agents": "^1.0.47",
    "@livekit/agents-plugin-cartesia": "^1.0.47",
    "@livekit/agents-plugin-deepgram": "^1.0.47",
    "@livekit/agents-plugin-livekit": "^1.0.47",
    "@livekit/agents-plugin-openai": "^1.0.47",
    "@livekit/agents-plugin-silero": "^1.0.47",
    "@mendable/firecrawl-js": "^4.13.1",
    "@orama/orama": "^3.1.18",
    "@orama/plugin-embeddings": "^3.1.18",
    "@tensorflow/tfjs-node": "^4.22.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "fishery": "^2.4.0",
    "google-auth-library": "^10.5.0",
    "google-libphonenumber": "^3.2.44",
    "jsonld": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.0",
    "node-html-parser": "^7.0.2",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "schema-dts": "^1.1.5",
    "tsyringe": "^4.8.0",
    "twilio": "^5.12.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/jsonld": "^1.5.15",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
