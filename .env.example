TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=phonetastic_dev

# LiveKit server connection
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Twilio Verify (phone number verification)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
# Test credentials only — use +15005550006 with Twilio test keys
# TWILIO_FROM_NUMBER=+15005550006

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# OpenAI (LLM)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Deepgram (STT)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Cartesia (TTS)
CARTESIA_API_KEY=your-cartesia-api-key

# Google OAuth (Calendar)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3333/v1/calendars/connect/callback

# Ngrok tunnel (for OAuth/webhook callbacks during development)
# 1. Sign up at https://ngrok.com and get your authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# 2. Claim a free static domain at https://dashboard.ngrok.com/cloud-edge/domains
NGROK_AUTHTOKEN=your-ngrok-authtoken
NGROK_DOMAIN=your-static-domain.ngrok-free.app
LOCAL_TUNNEL_SUFFIX=your-username
